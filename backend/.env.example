# ============================================================
# SmartSeat AI — Backend Environment Variables
# ============================================================
# Copy to .env and fill in values

# Application
APP_NAME="SmartSeat AI"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/smartseat?sslmode=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# JWT Authentication
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# OpenAI (leave empty to use mock AI provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=10

# Redis (optional - for caching)
REDIS_URL=

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx
